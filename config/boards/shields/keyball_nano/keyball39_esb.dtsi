#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
    esb_link {
        compatible = "zmk,split-esb";
        base-address = [2D E9 73 5C];
        hop-channels = [4A 4E 52];
        hop-anchors = [4A 4E 52];
        tx-power-dbm = <8>;
        use-fast-ramp-up;
        hop-threshold = <24>;
        hop-window-ms = <24>;
        peripheral-timeout-ms = <1000>;
        retransmit-count = <8>;
        retransmit-delay-us = <1000>;
        survey-threshold-dbm = <0>;
        bitrate-kbps = <1000>;
        lossy-codes
            = <INPUT_EV_REL INPUT_REL_X>
            , <INPUT_EV_REL INPUT_REL_Y>
            ;

        peripherals {
            left_esb: peripheral_left {
                pipe = <0>;
                prefix = <0xA6>;
                weight = <4>;
            };

            right_esb: peripheral_right {
                pipe = <1>;
                prefix = <0x5B>;
                weight = <1>;
            };
        };
    };

    split_inputs {
        #address-cells = <1>;
        #size-cells = <0>;

        split_trackball: split_trackball@1 {
            compatible = "zmk,input-split";
            reg = <1>;
            status = "disabled";
        };
    };
};
